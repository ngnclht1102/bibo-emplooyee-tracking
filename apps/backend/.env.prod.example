# PRODUCTION backend config. Copy to .env (or let scripts/start-env.sh export these).
# Separate Postgres database from dev/staging — never shares state.
#
# Local run: scripts/dev-db.sh creates the `ctracking_prod` database for you.
# Real production (bibotracker.com) overrides DATABASE_URL/JWT_SECRET via its own .env.

# HTTP port (distinct from dev :8080 / staging :8081 so envs can run side by side locally).
PORT=8082

# Postgres — production database.
DATABASE_URL=postgres://ctracking:ctracking@localhost:5432/ctracking_prod?sslmode=disable

# Secret used to sign JWT access/refresh tokens. MUST be a long random value in real prod.
JWT_SECRET=prod-change-me-to-a-long-random-secret

# Root directory for on-disk screenshot storage (no S3). Per-env so blobs don't mix.
STORAGE_DIR=./storage-prod

# Origin allowed by CORS (the web-admin dev server).
WEB_ADMIN_ORIGIN=http://localhost:5174
