# STAGING backend config. Copy to .env (or let scripts/start-env.sh export these).
# Separate Postgres database from dev/prod — never shares state.
#
# Local run: scripts/dev-db.sh creates the `ctracking_staging` database for you.
# Real staging (VPS) overrides DATABASE_URL/JWT_SECRET via its own on-disk .env.

# HTTP port (distinct from dev :8080 so envs can run side by side locally).
PORT=8081

# Postgres — staging database.
DATABASE_URL=postgres://ctracking:ctracking@localhost:5432/ctracking_staging?sslmode=disable

# Secret used to sign JWT access/refresh tokens. Use a long random value in real staging.
JWT_SECRET=staging-only-change-me

# Root directory for on-disk screenshot storage (no S3). Per-env so blobs don't mix.
STORAGE_DIR=./storage-staging

# Origin allowed by CORS (the web-admin dev server).
WEB_ADMIN_ORIGIN=http://localhost:5174
