# DEV / LOCAL backend config. Copy to .env for local dev.
# One of three per-environment configs (see .env.staging.example / .env.prod.example);
# each env uses a SEPARATE Postgres database so dev/staging/prod never share state.

# HTTP port the backend listens on (staging uses :8081, production :8082 locally).
PORT=8080

# Postgres connection string.
DATABASE_URL=postgres://ctracking:ctracking@localhost:5432/ctracking?sslmode=disable

# Secret used to sign JWT access/refresh tokens. Use a long random value in prod.
JWT_SECRET=dev-only-change-me

# Root directory for on-disk screenshot storage (no S3).
STORAGE_DIR=./storage

# Origin allowed by CORS (the web-admin dev server).
WEB_ADMIN_ORIGIN=http://localhost:5174

# Deploy environment label sent to Sentry (local/staging/production).
APP_ENV=local

# Sentry DSN for backend error reporting. Leave EMPTY to disable (recommended for
# local dev). Production uses the backend project DSN.
SENTRY_DSN=

# Secret token for the CPU keep-alive endpoint (POST /v1/keepalive). Leave EMPTY to
# DISABLE the route entirely (recommended for local/staging). Set a long random value
# in production to keep the Oracle Always Free box above the idle-reclamation threshold.
KEEPALIVE_TOKEN=
