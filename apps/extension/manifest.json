{
  "manifest_version": 3,
  "name": "ctracking",
  "version": "0.1.0",
  "description": "Reports the active browser tab (URL + time on page) to the local ctracking app.",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ctracking"
  }
}
