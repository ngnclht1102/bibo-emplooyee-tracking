# Copy to deploy/.env.deploy (gitignored) and fill in. Used by deploy.sh.

# SSH target for the VPS.
VPS_HOST=namng@ssh.namnguyen.pro

# App directory on the VPS, relative to the remote home (~).
REMOTE_DIR=ctracking

# Port the backend listens on (serves API + web admin).
PORT=8080

# Postgres connection (the role/password you created in the GUI step).
DATABASE_URL=postgres://ctracking:CHANGE_ME@127.0.0.1:5432/ctracking?sslmode=disable

# Public origin the web admin is reached at (used for the CORS allowlist; with the
# SPA served same-origin it's mostly informational).
PUBLIC_ORIGIN=http://ssh.namnguyen.pro:8080
